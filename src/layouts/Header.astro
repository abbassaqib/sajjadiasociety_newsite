---
import NavMenu from "@/components/NavMenu";
import Sidebar from "@/components/Sidebar";
import StyledText from "@/components/StyledText";
import { menu } from "@/utils/getMenuItems";
import { Image } from "astro:assets";
import { type ImageMetadata } from "astro";
import { siteConfig } from "@/data/contentCollectionDataFetching";

const logoImage = import.meta.glob<{ default: ImageMetadata }>(`src/assets/*`);

const currentPath = Astro.url.pathname;
---

<header
  class:list={["layout-full py-4 h-26 bg-sidebar text-sidebar-foreground", currentPath !== "/" && "border-b border-sidebar-border"]}
>
  <div class="flex w-full items-center">
    {
      siteConfig?.data.header?.displayLogo && siteConfig.data.general.logo && (
        <Image
          src={logoImage[`/${siteConfig.data.general.logo}`]()}
          alt="Sajjadia Islamic Society logo"
          class={"max-h-24 w-auto"}
        />
      )
    }

    {
      siteConfig?.data.header?.displayTitle ? (
        <StyledText as="h2" variant="displayLG" className="flex-1">
          <a href="/">{siteConfig?.data.general.name}</a>
        </StyledText>
      ) : (
        <h2 class="sr-only">{siteConfig?.data.general.name}</h2>
      )
    }

    <button
      id="theme-toggle"
      aria-label="Toggle light/dark mode"
      class="rounded-md p-2 text-primary-foreground/70 hover:text-primary-foreground hover:bg-primary-foreground/10 transition-colors"
    >
      <span id="theme-icon-sun" class="hidden">☀️</span>
      <span id="theme-icon-moon" class="hidden">🌙</span>
    </button>

    <NavMenu
      className="hidden gap-2 lg:inline-flex items-center flex-wrap"
      menu={menu}
      client:load
    />

    <Sidebar menu={menu} client:load />
  </div>

  <script>
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('theme-icon-sun');
  const moon = document.getElementById('theme-icon-moon');

  function updateIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    sun!.classList.toggle('hidden', !isDark);
    moon!.classList.toggle('hidden', isDark);
  }

  updateIcon();

  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    updateIcon();
  });
</script>
</header>
