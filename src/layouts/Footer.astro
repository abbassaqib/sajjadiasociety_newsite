---
import StyledText from "@/components/StyledText";
import SubscribeForm from "@/components/SubscribeForm";
import SocialMediaLinks from "@/components/SocialMediaLinks";
import { siteConfig } from "@/data/contentCollectionDataFetching";
import { getSiteSettings } from "@/data/sanityQueries";
import { getCampaign } from "@/data/sanityQueries";

const form = siteConfig?.data.footer?.form;

const RESEND_SEGMENT_ID = import.meta.env.RESEND_SEGMENT_ID;
const RESEND_API_KEY = import.meta.env.RESEND_API_KEY;

// Pull contact + social from Sanity as single source of truth
const sanitySettings = await getSiteSettings();
const campaign = await getCampaign();
const contact = sanitySettings?.contact;
const socialMedia = sanitySettings?.socialMedia;
const locations = sanitySettings?.locations;

// Build social array for SocialMediaLinks component
const socialLinks = [
  socialMedia?.facebook && {
    name: "Facebook",
    icon: "simple-icons:facebook",
    link: socialMedia.facebook,
  },
  socialMedia?.youtube && {
    name: "YouTube",
    icon: "simple-icons:youtube",
    link: socialMedia.youtube,
  },
].filter(Boolean) as { name: string; icon: string; link: string }[];

// Primary location (if set)
const primaryLocation = locations?.find((l: any) => l.isPrimary) ?? locations?.[0];

const donorboxUrl = campaign.donorboxLink ?? ''
const donorboxCampaign = donorboxUrl.split('/').pop() ?? ''
---

<footer class="bg-sidebar text-sidebar-foreground layout-base py-8">
  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

    <!-- Left — Contact info -->
    <section class="flex flex-col gap-4">
      <h2 class="sr-only">Contact Info</h2>

      {primaryLocation && (
        <div class="flex flex-col gap-1">
          <StyledText as="h3" variant="heading" className="pb-1">
            Programs & Congregations
          </StyledText>
          <p class="text-sidebar-foreground/70 text-sm leading-relaxed">
            We currently hold programs at various community locations in Riverside County.
            Check our programs page for current locations and times.
          </p>
        </div>
      )}

      {!primaryLocation && (
        <div class="flex flex-col gap-1">
          <StyledText as="h3" variant="heading" className="pb-1">
            Programs & Congregations
          </StyledText>
          <p class="text-sidebar-foreground/70 text-sm leading-relaxed">
            We currently hold programs at various community locations in Riverside County.
          </p>
        </div>
      )}

      <div class="flex flex-col gap-1">
        <StyledText as="h3" variant="heading" className="pb-1">
          Contact Us
        </StyledText>
        {contact?.email && (
          <a
            href={`mailto:${contact.email}`}
            class="text-sidebar-foreground/70 hover:text-sidebar-foreground text-sm transition-colors"
          >
            {contact.email}
          </a>
        )}
        {contact?.phone1 && (
          <p class="text-sidebar-foreground/70 text-sm">
            {contact.phone1Label && <span class="text-sidebar-foreground/50 text-xs">{contact.phone1Label}: </span>}
            <a href={`tel:${contact.phone1}`} class="hover:text-sidebar-foreground transition-colors">
              {contact.phone1}
            </a>
          </p>
        )}
        {contact?.phone2 && (
          <p class="text-sidebar-foreground/70 text-sm">
            {contact.phone2Label && <span class="text-sidebar-foreground/50 text-xs">{contact.phone2Label}: </span>}
            <a href={`tel:${contact.phone2}`} class="hover:text-sidebar-foreground transition-colors">
              {contact.phone2}
            </a>
          </p>
        )}
      </div>

      <!-- Contact Us button -->
      <button
        data-contact-trigger
        class="w-fit inline-flex items-center gap-2 bg-accent text-accent-foreground font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-accent/90 transition-colors"
      >
        ✉ Contact Us
      </button>

      <!-- Social icons — wrapped to override color -->
      {socialLinks.length > 0 && (
        <div class="[&_a]:text-sidebar-foreground/60 [&_a:hover]:text-sidebar-foreground [&_a]:transition-colors">
          <SocialMediaLinks social={socialLinks} client:idle />
        </div>
      )}
    </section>

    <!-- Middle — Newsletter (hidden until Resend is set up) -->
    {form?.isActive && RESEND_SEGMENT_ID && RESEND_API_KEY ? (
      <section class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
          <StyledText as="h2" variant="heading" set:html={form.heading} />
          <div set:html={form.description} />
        </div>
        <SubscribeForm client:idle />
      </section>
    ) : (
      <section class="flex flex-col gap-4">
        <StyledText as="h2" variant="heading">
          Stay Connected
        </StyledText>
        <p class="text-sidebar-foreground/70 text-sm leading-relaxed">
          Follow us on Facebook and YouTube for the latest announcements, programs, and community updates.
        </p>
        <div class="flex flex-col gap-2">
          {socialMedia?.facebook && (
            <a
              href={socialMedia.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sidebar-foreground/70 hover:text-sidebar-foreground text-sm transition-colors"
            >
              <span>📘</span> Facebook
            </a>
          )}
          {socialMedia?.youtube && (
            <a
              href={socialMedia.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sidebar-foreground/70 hover:text-sidebar-foreground text-sm transition-colors"
            >
              <span>▶️</span> YouTube
            </a>
          )}
        </div>
      </section>
    )}

    <!-- Right — Donate -->
    <section class="flex flex-col gap-4">
      <StyledText as="h2" variant="heading">
        Support Sajjadia
      </StyledText>
      <p class="text-sidebar-foreground/70 text-sm leading-relaxed">
        Help us build a permanent home for our community.
        Every contribution makes a difference.
      </p>

      <script type="module" src="https://donorbox.org/widgets.js" async></script>
      <dbox-widget
        campaign={donorboxCampaign}
        type="popup"
        button-label="Quick Donate"
        button-type="regular"
        button-color="#b8860b"
        button-size="medium"
        show-icon="">
      </dbox-widget>
    </section>

  </div>

  <!-- Bottom bar -->
  <div class="mt-8 pt-6 border-t border-sidebar-border flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between text-xs text-sidebar-foreground/40">
    <p>© {new Date().getFullYear()} Sajjadia Islamic Society. All rights reserved.</p>
    <p>Registered 501(c)(3) Nonprofit Organization</p>
  </div>

</footer>