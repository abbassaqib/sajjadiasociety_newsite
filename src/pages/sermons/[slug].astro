---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Lightbox from "@/components/Lightbox.astro";
import { sanityClient, urlFor } from "@/lib/sanity";

export async function getStaticPaths() {
  const lectures = await sanityClient.fetch(`
    *[_type == "program" && isPublished == true && type == "lecture"] {
      "slug": slug.current
    }
  `);
  return lectures.map((l: any) => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;

const lecture = await sanityClient.fetch(`
  *[_type == "program"
    && slug.current == $slug
    && isPublished == true
    && type == "lecture"][0] {
    _id, title, isRecurring, recurrencePattern,
    startDate, endDate, location, locationAddress,
    speaker, description, image,
    registrationRequired, registrationLink
  }
`, { slug });

if (!lecture) return Astro.redirect("/sermons");

function formatDateRange(startStr: string, endStr?: string): string {
  const start = new Date(startStr);
  const startLabel = start.toLocaleDateString("en-US", {
    weekday: "long", month: "long", day: "numeric", year: "numeric",
  });
  if (!endStr) return startLabel;
  const end = new Date(endStr);
  return `${startLabel} – ${end.toLocaleDateString("en-US", {
    weekday: "long", month: "long", day: "numeric", year: "numeric",
  })}`;
}

function formatTime(dateStr: string): string {
  return new Date(dateStr).toLocaleTimeString("en-US", {
    hour: "numeric", minute: "2-digit",
  });
}

function renderBody(blocks: any[]): string {
  if (!blocks) return "";
  return blocks.map((block: any) => {
    if (block._type !== "block") return "";
    const text = block.children
      ?.map((child: any) => {
        let t = child.text ?? "";
        if (child.marks?.includes("strong")) t = `<strong>${t}</strong>`;
        if (child.marks?.includes("em")) t = `<em>${t}</em>`;
        return t;
      })
      .join("") ?? "";
    if (!text.trim()) return "";
    if (block.style === "h3") return `<h3 class="text-2xl font-semibold mt-8 mb-3">${text}</h3>`;
    return `<p class="mb-5 leading-relaxed text-lg">${text}</p>`;
  }).join("");
}

const dateRange = formatDateRange(lecture.startDate, lecture.endDate);
const timeLabel = formatTime(lecture.startDate);
const bodyHtml = renderBody(lecture.description);

const thumbUrl = lecture.image
  ? urlFor(lecture.image).width(900).height(500).fit("crop").url()
  : null;
const fullUrl = lecture.image
  ? urlFor(lecture.image).width(2000).url()
  : null;
---

<BaseLayout pageTitle={lecture.title}>
  <main class="layout-base gap-8 py-10">

    <a href="/sermons" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to Lectures
    </a>

    {thumbUrl && fullUrl && (
      <Lightbox
        id={lecture._id}
        src={fullUrl}
        alt={lecture.title}
        thumbnailSrc={thumbUrl}
      />
    )}

    <div class="border-b border-border pb-6">
      <span class="text-xs font-medium bg-secondary/10 text-secondary px-3 py-1 rounded-full mb-4 inline-block">
        📖 Islamic Lecture
      </span>

      <h1 class="text-3xl font-bold uppercase tracking-wider mt-3 mb-4">
        {lecture.title}
      </h1>

      <div class="flex flex-col gap-2 text-muted-foreground text-sm">
        <div class="flex items-start gap-2">
          <span>📅</span><span>{dateRange}</span>
        </div>
        <div class="flex items-center gap-2">
          <span>🕐</span>
          <span>{timeLabel}</span>
          {lecture.isRecurring && lecture.recurrencePattern && (
            <span class="text-muted-foreground/60">({lecture.recurrencePattern})</span>
          )}
        </div>
        {lecture.location && (
          <div class="flex items-start gap-2">
            <span>📍</span>
            <span>
              {lecture.location}
              {lecture.locationAddress && (
                <span class="text-muted-foreground/60"> — {lecture.locationAddress}</span>
              )}
            </span>
          </div>
        )}
        {lecture.speaker && (
          <div class="flex items-center gap-2">
            <span>🎤</span><span>{lecture.speaker}</span>
          </div>
        )}
      </div>
    </div>

    {bodyHtml && (
      <div
        class="prose prose-lg max-w-none dark:prose-invert text-foreground"
        set:html={bodyHtml}
      />
    )}

    {lecture.registrationRequired && lecture.registrationLink && (
      <div class="bg-secondary/10 border border-secondary/20 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-2">Registration Required</h2>
        <p class="text-muted-foreground text-sm mb-4">
          Please register in advance to attend this lecture.
        </p>
        <a
          href={lecture.registrationLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-secondary text-secondary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-secondary/90 transition-colors"
        >
          Register Now →
        </a>
      </div>
    )}

    <a href="/sermons" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to Lectures
    </a>

  </main>
</BaseLayout>