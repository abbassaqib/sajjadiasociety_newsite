---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Lightbox from "@/components/Lightbox.astro";
import { sanityClient, urlFor } from "@/lib/sanity";
import { cn } from "@/lib/utils";

const now = new Date().toISOString();

const [upcoming, past] = await Promise.all([
  sanityClient.fetch(`
    *[_type == "program"
      && isPublished == true
      && type == "lecture"
      && startDate > $now]
    | order(startDate asc) [0...20] {
      _id, title, slug, type, isRecurring,
      recurrencePattern, startDate, endDate,
      location, speaker, description, image
    }
  `, { now }),
  sanityClient.fetch(`
    *[_type == "program"
      && isPublished == true
      && type == "lecture"
      && startDate <= $now]
    | order(startDate desc) [0...30] {
      _id, title, slug, startDate,
      location, speaker, image
    }
  `, { now }),
]);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    weekday: "long", month: "long", day: "numeric", year: "numeric",
  });
}

function formatTime(dateStr: string) {
  return new Date(dateStr).toLocaleTimeString("en-US", {
    hour: "numeric", minute: "2-digit",
  });
}
---

<BaseLayout pageTitle="Lectures">
  <main class="layout-base gap-10 py-10">

    <div class="border-b border-border pb-6">
      <h1 class="text-3xl font-bold uppercase tracking-wider mb-2">
        📖 Islamic Lectures
      </h1>
      <p class="text-muted-foreground">
        Upcoming and past lectures, talks, and Islamic educational programs from Sajjadia Islamic Society.
      </p>
    </div>

    <section>
      <h2 class="text-xl font-semibold uppercase tracking-wider mb-6 text-primary">
        Upcoming Lectures
      </h2>

      {upcoming && upcoming.length > 0 ? (
        <div class="flex flex-col gap-6">
          {upcoming.map((lecture: any) => {
            const thumbUrl = lecture.image
              ? urlFor(lecture.image).width(600).height(400).fit("crop").url()
              : null;
            const fullUrl = lecture.image
              ? urlFor(lecture.image).width(1600).url()
              : null;

            return (
              <div class="bg-card border border-border rounded-xl overflow-hidden hover:border-secondary transition-colors">
                <div class="flex flex-col sm:flex-row">
                  {thumbUrl && fullUrl && (
                    <div class="sm:w-64 flex-shrink-0">
                      <Lightbox
                        id={lecture._id}
                        src={fullUrl}
                        alt={lecture.title}
                        thumbnailSrc={thumbUrl}
                      />
                    </div>
                  )}
                  <div class="flex flex-col gap-3 p-6 flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <div class="bg-primary text-primary-foreground rounded-lg px-3 py-1">
                        <span class="text-xs font-medium uppercase tracking-wider opacity-80">
                          {new Date(lecture.startDate).toLocaleDateString("en-US", { month: "short" })}
                        </span>
                        <span class="text-xl font-bold ml-1">
                          {new Date(lecture.startDate).getDate()}
                        </span>
                      </div>
                      <span class="text-xs font-medium bg-secondary/10 text-secondary px-2 py-0.5 rounded-full">
                        📖 Lecture
                      </span>
                      {lecture.isRecurring && (
                        <span class="text-xs bg-muted text-muted-foreground px-2 py-0.5 rounded-full">
                          🔁 Recurring
                        </span>
                      )}
                    </div>

                    <a
                      href={`/sermons/${lecture.slug?.current}`}
                      class="text-lg font-semibold hover:text-secondary transition-colors"
                    >
                      {lecture.title}
                    </a>

                    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
                      <span>📅 {formatDate(lecture.startDate)}</span>
                      <span>🕐 {formatTime(lecture.startDate)}</span>
                      {lecture.location && <span>📍 {lecture.location}</span>}
                      {lecture.speaker && <span>🎤 {lecture.speaker}</span>}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="bg-muted rounded-xl p-10 text-center">
          <p class="text-muted-foreground text-lg mb-2">No upcoming lectures scheduled</p>
          <p class="text-muted-foreground text-sm">
            Follow us on{" "}
            <a
              href="https://www.facebook.com/sajjadiaislamicsociety"
              class="text-secondary hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Facebook
            </a>{" "}
            for updates on upcoming lectures.
          </p>
        </div>
      )}
    </section>

    {past && past.length > 0 && (
      <section>
        <h2 class="text-xl font-semibold uppercase tracking-wider mb-6 text-muted-foreground">
          Past Lectures
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {past.map((lecture: any) => {
            const thumbUrl = lecture.image
              ? urlFor(lecture.image).width(400).height(260).fit("crop").url()
              : null;
            const fullUrl = lecture.image
              ? urlFor(lecture.image).width(1600).url()
              : null;

            return (
              <div class="bg-card border border-border rounded-xl overflow-hidden hover:border-secondary transition-colors group">
                {thumbUrl && fullUrl && (
                  <Lightbox
                    id={`past-${lecture._id}`}
                    src={fullUrl}
                    alt={lecture.title}
                    thumbnailSrc={thumbUrl}
                  />
                )}
                <div class="p-5">
                  <span class="text-xs font-medium bg-secondary/10 text-secondary px-2 py-0.5 rounded-full mb-3 inline-block">
                    📖 Lecture
                  </span>
                  <a
                    href={`/sermons/${lecture.slug?.current}`}
                    class="block font-semibold group-hover:text-secondary transition-colors mb-2"
                  >
                    {lecture.title}
                  </a>
                  <p class="text-muted-foreground text-sm">
                    {formatDate(lecture.startDate)}
                  </p>
                  {lecture.speaker && (
                    <p class="text-muted-foreground text-sm mt-1 italic">
                      {lecture.speaker}
                    </p>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

  </main>
</BaseLayout>