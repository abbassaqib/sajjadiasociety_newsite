---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Lightbox from "@/components/Lightbox.astro";
import { sanityClient, urlFor } from "@/lib/sanity";

export async function getStaticPaths() {
  const programs = await sanityClient.fetch(`
    *[_type == "program" && isPublished == true] {
      "slug": slug.current
    }
  `);
  return programs.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const program = await sanityClient.fetch(`
  *[_type == "program" && slug.current == $slug && isPublished == true][0] {
    _id, title, type, isRecurring, recurrencePattern,
    startDate, endDate, location, locationAddress,
    speaker, description, image,
    registrationRequired, registrationLink
  }
`, { slug });

if (!program) return Astro.redirect("/programs");

const programTypeLabel: Record<string, string> = {
  jummah:            "🕌 Jummah Prayer",
  lecture:           "📖 Islamic Lecture",
  special_event:     "⭐ Special Event",
  quran_class:       "📚 Quran Class",
  youth:             "👥 Youth Program",
  community_service: "🤝 Community Service",
  islamic_occasion:  "☪️ Islamic Occasion",
};

// Start date always shown; end date only if present
function formatDateRange(startStr: string, endStr?: string): string {
  const start = new Date(startStr);
  const startLabel = start.toLocaleDateString("en-US", {
    weekday: "long", month: "long", day: "numeric", year: "numeric",
  });
  if (!endStr) return startLabel;
  const end = new Date(endStr);
  const endLabel = end.toLocaleDateString("en-US", {
    weekday: "long", month: "long", day: "numeric", year: "numeric",
  });
  return `${startLabel} – ${endLabel}`;
}

function formatTime(dateStr: string): string {
  return new Date(dateStr).toLocaleTimeString("en-US", {
    hour: "numeric", minute: "2-digit",
  });
}

const dateRange = formatDateRange(program.startDate, program.endDate);
const timeLabel = formatTime(program.startDate);

const thumbUrl = program.image
  ? urlFor(program.image).width(900).height(500).fit("crop").url()
  : null;
const fullUrl = program.image
  ? urlFor(program.image).width(2000).url()
  : null;

function renderBody(blocks: any[]): string {
  if (!blocks) return "";
  return blocks.map((block: any) => {
    if (block._type !== "block") return "";
    const text = block.children
      ?.map((child: any) => {
        let t = child.text ?? "";
        if (child.marks?.includes("strong")) t = `<strong>${t}</strong>`;
        if (child.marks?.includes("em")) t = `<em>${t}</em>`;
        return t;
      })
      .join("") ?? "";
    if (block.style === "h3") return `<h3 class="text-xl font-semibold mt-6 mb-2">${text}</h3>`;
    return `<p class="mb-4 leading-relaxed">${text}</p>`;
  }).join("");
}

const bodyHtml = renderBody(program.description);
---

<BaseLayout pageTitle={program.title}>
  <main class="layout-base gap-8 py-10">

    <a href="/news-events" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to News & Events
    </a>

    {thumbUrl && fullUrl && (
      <Lightbox id={program._id} src={fullUrl} alt={program.title} thumbnailSrc={thumbUrl} />
    )}

    <div class="border-b border-border pb-6">
      <span class="text-xs font-medium bg-primary/10 text-primary px-3 py-1 rounded-full mb-4 inline-block">
        {programTypeLabel[program.type] ?? "📅 Program"}
      </span>

      <h1 class="text-3xl font-bold uppercase tracking-wider mt-3 mb-4">
        {program.title}
      </h1>

      <div class="flex flex-col gap-2 text-muted-foreground text-sm">
        <!-- Date range: start only, or start – end -->
        <div class="flex items-start gap-2">
          <span>📅</span>
          <span>{dateRange}</span>
        </div>
        <!-- Time -->
        <div class="flex items-center gap-2">
          <span>🕐</span>
          <span>{timeLabel}</span>
          {program.isRecurring && program.recurrencePattern && (
            <span class="text-muted-foreground/60">({program.recurrencePattern})</span>
          )}
        </div>
        {program.location && (
          <div class="flex items-start gap-2">
            <span>📍</span>
            <span>
              {program.location}
              {program.locationAddress && (
                <span class="text-muted-foreground/60"> — {program.locationAddress}</span>
              )}
            </span>
          </div>
        )}
        {program.speaker && (
          <div class="flex items-center gap-2">
            <span>🎤</span><span>{program.speaker}</span>
          </div>
        )}
      </div>
    </div>

    {bodyHtml && (
      <div
        class="prose prose-lg max-w-none dark:prose-invert text-foreground"
        set:html={bodyHtml}
      />
    )}

    {program.registrationRequired && program.registrationLink && (
      <div class="bg-secondary/10 border border-secondary/20 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-2">Registration Required</h2>
        <p class="text-muted-foreground text-sm mb-4">
          Please register in advance to attend this program.
        </p>
        <a
          href={program.registrationLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-secondary text-secondary-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-secondary/90 transition-colors"
        >
          Register Now →
        </a>
      </div>
    )}

    <a href="/news-events" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to News & Events
    </a>

  </main>
</BaseLayout>