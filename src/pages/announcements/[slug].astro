---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sanityClient } from "@/lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`
    *[_type == "announcement" && status == "approved"] {
      "slug": slug.current
    }
  `);
  return items.map((item: any) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;

const announcement = await sanityClient.fetch(`
  *[_type == "announcement"
    && status == "approved"
    && slug.current == $slug][0] {
    title, category, publishDate,
    expiryDate, isPinned, body, image
  }
`, { slug });

if (!announcement) return Astro.redirect("/announcements");

const categoryLabel: Record<string, string> = {
  general:          "General",
  jummah:           "🕌 Jummah",
  program:          "📅 Program",
  campaign:         "💰 Campaign",
  community:        "🤝 Community",
  islamic_occasion: "☪️ Islamic Occasion",
};

const dateLabel = announcement.publishDate
  ? new Date(announcement.publishDate).toLocaleDateString("en-US", {
      weekday: "long", month: "long", day: "numeric", year: "numeric",
    })
  : "";

// Render portable text blocks as plain HTML
function renderBody(blocks: any[]): string {
  if (!blocks) return "";
  return blocks.map((block: any) => {
    if (block._type !== "block") return "";
    const text = block.children
      ?.map((child: any) => {
        let t = child.text ?? "";
        if (child.marks?.includes("strong")) t = `<strong>${t}</strong>`;
        if (child.marks?.includes("em")) t = `<em>${t}</em>`;
        return t;
      })
      .join("") ?? "";
    if (block.style === "h3") return `<h3 class="text-xl font-semibold mt-6 mb-2">${text}</h3>`;
    return `<p class="mb-4 leading-relaxed">${text}</p>`;
  }).join("");
}

const bodyHtml = renderBody(announcement.body);
---

<BaseLayout pageTitle={announcement.title}>
  <main class="layout-base gap-8 py-10">

    <!-- Back link -->
    <a href="/announcements" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to Announcements
    </a>

    <!-- Header -->
    <div class="border-b border-border pb-6">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {announcement.category && (
          <span class="text-xs font-medium bg-primary/10 text-primary px-3 py-1 rounded-full">
            {categoryLabel[announcement.category] ?? announcement.category}
          </span>
        )}
        {announcement.isPinned && (
          <span class="text-xs font-medium bg-accent/10 text-accent px-3 py-1 rounded-full">
            📌 Pinned
          </span>
        )}
      </div>

      <h1 class="text-3xl font-bold uppercase tracking-wider mb-3">
        {announcement.title}
      </h1>

      {dateLabel && (
        <p class="text-muted-foreground text-sm">{dateLabel}</p>
      )}
    </div>

    <!-- Body content -->
    {bodyHtml && (
      <div
        class="prose prose-lg max-w-none dark:prose-invert text-foreground"
        set:html={bodyHtml}
      />
    )}

    <!-- Back -->
    <div class="border-t border-border pt-6">
      <a href="/announcements" class="text-secondary text-sm hover:underline underline-offset-4">
        ← Back to Announcements
      </a>
    </div>

  </main>
</BaseLayout>
