---
import { type ImageMetadata } from "astro";
import { Image } from "astro:assets";
// import StyledText from "@/components/StyledText";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/data/contentCollectionDataFetching";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import { urlFor } from "@/lib/sanity";
import {
  getCampaign,
  getAnnouncements,
  getUpcomingPrograms,
  getPrayerTimesConfig,
  getSiteSettings,
  getOrgInfo,
} from "@/data/sanityQueries";

// ── Fetch Sanity data in parallel ─────────────────────
const [campaign, announcements, programs, prayerConfig, sanitySettings, org] = await Promise.all([
  getCampaign(),
  getAnnouncements(6),
  getUpcomingPrograms(6),
  getPrayerTimesConfig(),
  getSiteSettings(),
  getOrgInfo(),
]);

// ── Prayer times from Aladhan API ─────────────────────
let prayerTimes = null;
if (prayerConfig?.useAladhanApi) {
  try {
    const { latitude, longitude } = prayerConfig.location;
    const method = prayerConfig.calculationMethod ?? "0";
    const today = new Date();
    const dateStr = `${today.getDate()}-${today.getMonth() + 1}-${today.getFullYear()}`;
    const res = await fetch(
      `https://api.aladhan.com/v1/timings/${dateStr}?latitude=${latitude}&longitude=${longitude}&method=${method}`
    );
    const json = await res.json();
    if (json.code === 200) prayerTimes = json.data.timings;
  } catch (e) {
    console.error("Aladhan API error:", e);
  }
}

const manualTimes = prayerConfig?.manualOverride;
const jummah = prayerConfig?.jummahDetails;
const isFriday = new Date().getDay() === 5;

function formatTime(time: string | undefined): string {
  if (!time) return "—";
  const [h, m] = time.split(":").map(Number);
  const ampm = h >= 12 ? "PM" : "AM";
  const hour = h % 12 || 12;
  return `${hour}:${String(m).padStart(2, "0")} ${ampm}`;
}

const displayTimes = [
  { name: "Fajr",    time: prayerTimes?.Fajr    ?? manualTimes?.fajr },
  { name: "Sunrise", time: prayerTimes?.Sunrise  ?? manualTimes?.sunrise },
  { name: "Zohr",    time: prayerTimes?.Dhuhr    ?? manualTimes?.zohr },
  { name: "Asr",     time: prayerTimes?.Asr      ?? manualTimes?.asr },
  { name: "Maghrib", time: prayerTimes?.Maghrib  ?? manualTimes?.maghrib },
  { name: "Isha",    time: prayerTimes?.Isha     ?? manualTimes?.isha },
];

const raised = campaign?.raisedAmount ?? 0;
const goal   = campaign?.goalAmount   ?? 60000;
const pct    = Math.min(Math.round((raised / goal) * 100), 100);

const hero = siteConfig?.data.body?.hero;

const bgImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/*.{jpeg,jpg,png,webp,svg}"
);
const selectedImage = hero?.bgImage ? bgImages[`/${hero.bgImage}`] : null;

const todayLabel = new Date().toLocaleDateString("en-US", {
  weekday: "long", month: "long", day: "numeric",
});

const programTypeLabel: Record<string, string> = {
  jummah:            "🕌 Jummah",
  lecture:           "📖 Lecture",
  special_event:     "⭐ Special Event",
  quran_class:       "📚 Quran Class",
  youth:             "👥 Youth",
  community_service: "🤝 Community",
  islamic_occasion:  "☪️ Occasion",
};

const topAnnouncements = announcements?.slice(0, 3) ?? [];
const topPrograms = programs?.slice(0, 3) ?? [];
const hasMoreAnnouncements = (announcements?.length ?? 0) > 3;
const hasMorePrograms = (programs?.length ?? 0) > 3;

const donorboxCampaign = (campaign?.donorboxLink ?? "").split("/").pop() ?? "";

const storyExcerpt = (campaign?.story ?? [])
  .filter((b: any) => b._type === "block" && b.style === "normal")
  .slice(0, 2)
  .map((b: any) => b.children?.map((c: any) => c.text ?? "").join("") ?? "")
  .filter(Boolean)
  .join(" ");

---

<BaseLayout pageTitle="Home">

  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO SECTION                                     -->
  <!-- ════════════════════════════════════════════════ -->
  <section
    class="hero relative flex w-full flex-col items-center justify-center overflow-hidden"
    aria-labelledby="hero-heading"
  >
    <h1 class="sr-only">{siteConfig?.data.general.name}</h1>

    <!-- Background image -->
    {selectedImage && (
      <>
        <Image
          src={selectedImage()}
          alt="Sajjadia Islamic Society"
          class="absolute inset-0 h-full w-full object-cover object-center"
          style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -1;"
          priority
        />
        <div class="absolute inset-0 bg-dark/90" aria-hidden="true" />
      </>
    )}

<div class="absolute inset-0 bg-dark/30" aria-hidden="true" />

    <!-- Hero content — centered with proper padding -->
    <div class="relative z-10 mx-auto w-full max-w-5xl px-8 py-16 text-center">

      <!-- Tagline -->
      <p class="text-foreground/50 mb-3 text-sm font-medium uppercase tracking-widest">
        <span class='text-secondary'>{sanitySettings?.tagline}</span>
      </p>
      <!-- <StyledText as="h2" id="hero-heading" variant="displayXL" set:html={hero?.text} className="mb-8" /> -->
      <p class="text-foreground/70 mt-2 mb-6 text-lg">
        <span class='text-secondary'>{sanitySettings?.shortDescription}</span>
      </p>

      <!-- Buttons -->
      <div class="mb-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        {campaign?.isActive && (
          <a
            href="/donate"
            class={cn(
              buttonVariants({ variant: "default" }),
              "h-auto bg-accent px-6 py-3 text-sm font-semibold text-accent-foreground hover:bg-accent/90"
            )}
          >
            💛 Donate to New Location Fund
          </a>
        )}
      </div>

      <!-- Prayer times card — rounded, centered, inline width -->
      <div class="mx-auto inline-block w-full max-w-2xl rounded-2xl bg-black/50 px-6 py-5 text-left backdrop-blur-md">

        <!-- Card header -->
        <div class="mb-4 flex flex-col gap-0.5 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-white text-sm font-semibold uppercase tracking-widest">
            🕐 Today's Prayer Times
          </p>
          <p class="text-white/50 text-xs">{todayLabel} · Corona, CA</p>
        </div>

        <!-- Prayer grid -->
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-6">
          {displayTimes.map(({ name, time }) => (
            <div class="rounded-xl bg-white/10 px-2 py-3 text-center">
              <p class="text-white/50 mb-1 text-[10px] font-medium uppercase tracking-wider">
                {name}
              </p>
              <p class="text-secondary text-sm font-bold">
                {formatTime(time)}
              </p>
            </div>
          ))}
        </div>

        <!-- Jummah row — Fridays only -->
        {isFriday && jummah && (
          <div class="mt-3 rounded-xl bg-white/10 px-4 py-3">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
              <p class="text-white text-sm font-semibold">🕌 Jummah Prayer Today</p>
              <p class="text-white/80 text-sm">
                Azaan: <span class="text-secondary font-semibold">{jummah.azaanTime}</span>
                &nbsp;·&nbsp;
                Khutba: <span class="text-secondary font-semibold">{jummah.khutbaTime}</span>
                {jummah.location && <>&nbsp;·&nbsp;<span class="text-white/60">{jummah.location}</span></>}
              </p>
              {jummah.additionalInfo && (
                <p class="text-white/40 text-xs italic">{jummah.additionalInfo}</p>
              )}
            </div>
          </div>
        )}

      </div>
      <!-- end prayer card -->

    </div>
    <!-- end hero content -->

  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- ANNOUNCEMENTS + EVENTS                           -->
  <!-- ════════════════════════════════════════════════ -->
  <section id="news-events" class="layout-full bg-background py-14 scroll-mt-24">
    <div class="layout-base">
      <div id="announcements" class="grid gap-10 lg:grid-cols-2">

        <!-- ANNOUNCEMENTS -->
        <div class="flex flex-col gap-4 scroll-mt-24">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold uppercase tracking-wider">📢 Announcements</h2>
            {hasMoreAnnouncements && (
              <a href="/news-events" class="text-secondary text-sm font-medium hover:underline underline-offset-4">See More →</a>
            )}
          </div>
          {topAnnouncements.length > 0 ? (
            <div class="flex flex-col gap-3">
              {topAnnouncements.map((item: any) => {
                const thumbUrl = item.image ? urlFor(item.image).width(300).height(200).fit("crop").url() : null;
                const fullUrl = item.image ? urlFor(item.image).width(1600).url() : null;
                const date = item.publishDate ? new Date(item.publishDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "";
                const bodyText = item.body?.filter((b: any) => b._type === "block").slice(0, 1).map((b: any) => b.children?.map((c: any) => c.text).join("")).join("") ?? "";
                return (
                  <div
                    class="card-trigger bg-card border border-border rounded-xl overflow-hidden hover:border-secondary transition-colors cursor-pointer flex"
                    data-title={item.title}
                    data-date={date}
                    data-body={bodyText}
                    data-img={fullUrl ?? ""}
                  >
                    {thumbUrl && (
                      <div class="w-24 flex-shrink-0">
                        <img src={thumbUrl} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                      </div>
                    )}
                    <div class="p-4 flex flex-col gap-1 min-w-0">
                      <p class="font-semibold text-sm leading-snug line-clamp-2">{item.title}</p>
                      {date && <p class="text-muted-foreground text-xs">{date}</p>}
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="bg-muted rounded-xl p-8 text-center text-muted-foreground text-sm">No announcements yet.</div>
          )}
        </div>

        <!-- EVENTS -->
        <div class="flex flex-col gap-4 scroll-mt-24">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold uppercase tracking-wider">📅 Events</h2>
            {hasMorePrograms && (
              <a href="/news-events" class="text-secondary text-sm font-medium hover:underline underline-offset-4">See More →</a>
            )}
          </div>
          {topPrograms.length > 0 ? (
            <div class="flex flex-col gap-3">
              {topPrograms.map((program: any) => {
                const thumbUrl = program.image ? urlFor(program.image).width(300).height(200).fit("crop").url() : null;
                const fullUrl = program.image ? urlFor(program.image).width(1600).url() : null;
                const dateLabel = new Date(program.startDate).toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" });
                const timeLabel = new Date(program.startDate).toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" });
                const bodyText = [dateLabel, timeLabel, program.location, program.speaker ? `Speaker: ${program.speaker}` : ""].filter(Boolean).join(" · ");
                return (
                  <div
                    class="card-trigger bg-card border border-border rounded-xl overflow-hidden hover:border-secondary transition-colors cursor-pointer flex"
                    data-title={program.title}
                    data-date={`${dateLabel} · ${timeLabel}`}
                    data-body={bodyText}
                    data-img={fullUrl ?? ""}
                    data-location={program.location ?? ""}
                    data-speaker={program.speaker ?? ""}
                  >
                    {thumbUrl && (
                      <div class="w-24 flex-shrink-0">
                        <img src={thumbUrl} alt={program.title} class="w-full h-full object-cover" loading="lazy" />
                      </div>
                    )}
                    <div class="p-4 flex flex-col gap-1 min-w-0">
                      <p class="font-semibold text-sm leading-snug line-clamp-2">{program.title}</p>
                      <p class="text-muted-foreground text-xs">{dateLabel} · {timeLabel}</p>
                      {program.location && <p class="text-muted-foreground text-xs">📍 {program.location}</p>}
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="bg-muted rounded-xl p-8 text-center text-muted-foreground text-sm">No upcoming events.</div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- CAMPAIGN / DONATE                                -->
  <!-- ════════════════════════════════════════════════ -->
  {campaign?.isActive && (
    <section id="donate" class="layout-full bg-sidebar text-sidebar-foreground py-14 scroll-mt-24">
      <div class="layout-base max-w-3xl mx-auto">
        <p class="text-accent text-sm font-semibold uppercase tracking-widest mb-2">Fundraising Campaign</p>
        <h2 class="text-3xl font-bold uppercase tracking-wider mb-3">{campaign.title}</h2>
        <p class="text-sidebar-foreground/70 mb-6 text-lg">{campaign.tagline}</p>
        <div class="bg-sidebar-foreground/10 h-3 rounded-full overflow-hidden mb-3">
          <div class="bg-accent h-3 rounded-full" style={`width: ${pct}%`} role="progressbar" aria-valuenow={pct} aria-valuemin={0} aria-valuemax={100} />
        </div>
        <div class="flex justify-between text-sm text-sidebar-foreground/70 mb-6">
          <span><span class="text-sidebar-foreground font-bold text-lg">${raised.toLocaleString()}</span> raised</span>
          <span>{pct}% of ${goal.toLocaleString()}</span>
        </div>
        {storyExcerpt && (
          <p class="text-sidebar-foreground/80 leading-relaxed mb-8">
            {storyExcerpt.slice(0, 300)}{storyExcerpt.length > 300 ? "..." : ""}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          {donorboxCampaign && (
            <dbox-widget campaign={donorboxCampaign} type="popup" button-label="💛 Donate Now" button-type="regular" button-color="#b8860b" button-size="medium" show-icon=""></dbox-widget>
          )}
          <a href="/donate" class={cn(buttonVariants({ variant: "ghost" }), "text-sidebar-foreground border border-sidebar-foreground/30 hover:bg-sidebar-foreground/10")}>
            Learn More →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════════════ -->
  <!-- ABOUT US                                         -->
  <!-- ════════════════════════════════════════════════ -->
  <section id="about" class="layout-full bg-background py-14 scroll-mt-24">
    <div class="layout-base">
      <h2 class="text-3xl font-bold uppercase tracking-wider mb-8">About Us</h2>
      <div class="grid gap-4 sm:grid-cols-3 mb-6">
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">2019</p>
          <p class="text-muted-foreground text-sm">Founded</p>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">501c3</p>
          <p class="text-muted-foreground text-sm">Registered Nonprofit</p>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">☽</p>
          <p class="text-muted-foreground text-sm">Shia Ithna Ashari</p>
        </div>
      </div>
      {org?.mission && (
        <div class="bg-card border border-border rounded-xl p-8 mb-4">
          <h3 class="font-semibold text-lg mb-3 text-primary">Our Mission</h3>
          <p class="text-foreground leading-relaxed">{org.mission}</p>
        </div>
      )}
      {org?.currentSituation && (
        <div class="bg-muted rounded-xl p-6 mb-6">
          <p class="text-foreground leading-relaxed">{org.currentSituation}</p>
        </div>
      )}
      <a href="/about-us" class={cn(buttonVariants({ variant: "outline" }), "w-fit")}>Learn More →</a>
    </div>
  </section>

</BaseLayout>

<!-- ════════════════════════════════════════════════ -->
<!-- CARD OVERLAY                                     -->
<!-- ════════════════════════════════════════════════ -->
<dialog id="card-overlay" class="fixed inset-0 z-50 bg-transparent p-4 max-w-none max-h-none w-screen h-screen m-0">
  <div class="w-full h-full flex items-center justify-center" id="card-overlay-backdrop">
    <div class="relative bg-background border border-border rounded-2xl shadow-2xl max-w-xl w-full max-h-[85vh] overflow-y-auto" onclick="event.stopPropagation()">
      <button id="card-overlay-close" class="absolute top-3 right-3 z-10 text-muted-foreground hover:text-foreground bg-background rounded-full p-1.5 border border-border" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <img id="card-overlay-img" src="" alt="" class="w-full max-h-96 object-contain bg-black rounded-t-2xl hidden" loading="lazy" />
      <div class="p-6">
        <h3 id="card-overlay-title" class="text-xl font-bold mb-2"></h3>
        <p id="card-overlay-date" class="text-muted-foreground text-sm mb-1"></p>
        <p id="card-overlay-location" class="text-muted-foreground text-sm mb-4 hidden"></p>
        <p id="card-overlay-body" class="text-foreground leading-relaxed"></p>
      </div>
    </div>
  </div>
</dialog>

<style>
  dialog { border: none; outline: none; background: transparent; padding: 0; margin: 0; }
  dialog::backdrop { background: rgba(0,0,0,0.85); backdrop-filter: blur(4px); }
  dialog[open] { display: flex; align-items: center; justify-content: center; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const overlay = document.getElementById('card-overlay') as HTMLDialogElement;
  const closeBtn = document.getElementById('card-overlay-close')!;
  const backdrop = document.getElementById('card-overlay-backdrop')!;
  const overlayImg = document.getElementById('card-overlay-img') as HTMLImageElement;
  const overlayTitle = document.getElementById('card-overlay-title')!;
  const overlayDate = document.getElementById('card-overlay-date')!;
  const overlayLocation = document.getElementById('card-overlay-location')!;
  const overlayBody = document.getElementById('card-overlay-body')!;

  function openOverlay(el: HTMLElement) {
    overlayTitle.textContent = el.dataset.title ?? '';
    overlayDate.textContent = el.dataset.date ?? '';
    overlayBody.textContent = el.dataset.body ?? '';
    const loc = [el.dataset.location, el.dataset.speaker ? `Speaker: ${el.dataset.speaker}` : ''].filter(Boolean).join(' · ');
    if (loc) { overlayLocation.textContent = loc; overlayLocation.classList.remove('hidden'); }
    else { overlayLocation.classList.add('hidden'); }
    const img = el.dataset.img ?? '';
    if (img) { overlayImg.src = img; overlayImg.alt = el.dataset.title ?? ''; overlayImg.classList.remove('hidden'); }
    else { overlayImg.classList.add('hidden'); }
    overlay.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeOverlay() { overlay.close(); document.body.style.overflow = ''; }

  closeBtn.addEventListener('click', closeOverlay);
  backdrop.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeOverlay(); });
  document.querySelectorAll('.card-trigger').forEach((card) => {
    card.addEventListener('click', () => openOverlay(card as HTMLElement));
  });
</script>