---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getOrgInfo } from "@/data/sanityQueries";

const org = await getOrgInfo();
---

<BaseLayout pageTitle="About Us">
  <main class="layout-base gap-10 py-10">

    <div class="border-b border-border pb-6">
      <h1 class="text-3xl font-bold uppercase tracking-wider mb-2">About Us</h1>
      <p class="text-muted-foreground">
        Learn about Sajjadia Islamic Society — who we are, what we believe, and where we're headed.
      </p>
    </div>

    <!-- Stat cards -->
    <section class="grid gap-4 sm:grid-cols-3">
      <div class="bg-card border border-muted-foreground rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">2019</p>
          <p class="text-foreground text-sm">Founded</p>
        </div>
        <div class="bg-card border border-muted-foreground rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">501c3</p>
          <p class="text-foreground text-sm">Registered Nonprofit</p>
        </div>
        <div class="bg-card border border-muted-foreground rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-primary mb-1">☽</p>
          <p class="text-foreground text-sm">Shia Ithna Ashari</p>
        </div>
    </section>

    <!-- Current Situation -->
    {org?.currentSituation && (
      <section class="bg-primary border border-muted-foreground text-primary-foreground rounded-2xl p-8">
        <h2 class="text-xl font-semibold mb-4">Our Current Situation</h2>
        <p class="text-primary-foreground/80 leading-relaxed">{org.currentSituation}</p>
        <a
          href="/donate"
          class="inline-block mt-6 bg-accent text-accent-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-accent/90 transition-colors"
        >
          Help Us Build The New Mosque →
        </a>
      </section>
    )}

    <!-- Mission card -->
    {org?.mission && (
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-primary rounded-full"></div>
          <h2 class="text-2xl font-semibold">Mission</h2>
        </div>
        <div class="bg-card border border-border rounded-xl p-8">
          <p class="text-foreground leading-relaxed text-lg">{org.mission}</p>
        </div>
      </section>
    )}

    <!-- Vision card -->
    {org?.vision && (
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-secondary rounded-full"></div>
          <h2 class="text-2xl font-semibold">Vision</h2>
        </div>
        <div class="bg-card border border-border rounded-xl p-8">
          <p class="text-foreground leading-relaxed text-lg">{org.vision}</p>
        </div>
      </section>
    )}

    <!-- Future Plans -->
    {org?.futurePlans && (
      <section class="bg-muted rounded-xl p-8">
        <h2 class="text-xl font-semibold mb-4">Future Plans</h2>
        <p class="text-foreground leading-relaxed">{org.futurePlans}</p>
      </section>
    )}

  </main>
</BaseLayout>