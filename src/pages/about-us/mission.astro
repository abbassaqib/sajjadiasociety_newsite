---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getOrgInfo } from "@/data/sanityQueries";

const org = await getOrgInfo();

function renderBody(blocks: any[]): string {
  if (!blocks) return "";
  return blocks.map((block: any) => {
    if (block._type !== "block") return "";
    const text = block.children
      ?.map((child: any) => {
        let t = child.text ?? "";
        if (child.marks?.includes("strong")) t = `<strong>${t}</strong>`;
        if (child.marks?.includes("em")) t = `<em>${t}</em>`;
        return t;
      })
      .join("") ?? "";
    if (!text.trim()) return "";
    if (block.style === "h3") return `<h3 class="text-2xl font-semibold mt-8 mb-3">${text}</h3>`;
    return `<p class="mb-5 leading-relaxed text-lg">${text}</p>`;
  }).join("");
}

const aboutHtml = renderBody(org?.about ?? []);
---

<BaseLayout pageTitle="Our Mission">
  <main class="layout-base gap-10 py-10">

    <a href="/about-us" class="text-secondary text-sm hover:underline underline-offset-4">
      ← Back to About Us
    </a>

    <div class="border-b border-border pb-6">
      <h1 class="text-3xl font-bold uppercase tracking-wider mb-2">Our Mission & Vision</h1>
      <p class="text-muted-foreground">
        The values and purpose that guide Sajjadia Islamic Society.
      </p>
    </div>

    {org?.mission && (
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-primary rounded-full"></div>
          <h2 class="text-2xl font-semibold">Mission</h2>
        </div>
        <div class="bg-card border border-border rounded-xl p-8">
          <p class="text-foreground leading-relaxed text-lg">{org.mission}</p>
        </div>
      </section>
    )}

    {org?.vision && (
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-secondary rounded-full"></div>
          <h2 class="text-2xl font-semibold">Vision</h2>
        </div>
        <div class="bg-card border border-border rounded-xl p-8">
          <p class="text-foreground leading-relaxed text-lg">{org.vision}</p>
        </div>
      </section>
    )}

    {aboutHtml && (
      <section>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-8 bg-accent rounded-full"></div>
          <h2 class="text-2xl font-semibold">About Sajjadia</h2>
        </div>
        <div
          class="prose prose-lg max-w-none dark:prose-invert text-foreground"
          set:html={aboutHtml}
        />
      </section>
    )}

    {org?.currentSituation && (
      <section class="bg-muted rounded-xl p-8">
        <h2 class="text-xl font-semibold mb-4">Current Situation</h2>
        <p class="text-foreground leading-relaxed">{org.currentSituation}</p>
      </section>
    )}

    {org?.futurePlans && (
      <section class="bg-primary text-primary-foreground rounded-2xl p-8">
        <h2 class="text-xl font-semibold mb-4">Future Plans</h2>
        <p class="text-primary-foreground/80 leading-relaxed">{org.futurePlans}</p>
        <a
          href="/donate"
          class="inline-block mt-6 bg-accent text-accent-foreground font-semibold px-6 py-3 rounded-lg text-sm hover:bg-accent/90 transition-colors"
        >
          💛 Support Our Campaign
        </a>
      </section>
    )}

    <div class="border-t border-border pt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <a href="/about-us" class="text-secondary text-sm hover:underline underline-offset-4">
        ← Back to About Us
      </a>
      <a href="/about-us/faq" class="text-secondary text-sm hover:underline underline-offset-4">
        View FAQ →
      </a>
    </div>

  </main>
</BaseLayout>